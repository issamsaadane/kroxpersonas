{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KroxPersonas",
  "version": "0.1.0",
  "identifier": "com.kroxpersonas.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "KroxPersonas",
        "width": 1100,
        "height": 720,
        "minWidth": 780,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyRjE3QzMyQkIxRjVCOEUKUldTT1d4KzdNbnp4b21DTlV0VW9GVWpoSjNmRnllaGpOZWVLZ1p5MXp6WUF6a3VJd3Y4dlphWUwK",
      "endpoints": [
        "https://github.com/issamsaadane/kroxpersonas/releases/latest/download/latest.json"
      ]
    }
  }
}
